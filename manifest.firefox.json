{
  "manifest_version": 2,
  "name": "Taprac",
  "version": "1.0.0",
  "description": "Auto-fill job applications using your Taprac (Bubble) profile.",
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "permissions": [
    "storage",
    "activeTab",
    "https://kimmiysaa.bubbleapps.io/*",
    "<all_urls>"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": [
        "browser-polyfill.js",
        "config.js",
        "content.js",
        "job-scraper.js",
        "form-filler.js"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    "sidebar.html",
    "sidebar.css",
    "login-popup.html",
    "login-popup.css",
    "icons/*"
  ]
}
