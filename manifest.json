{\n  \"manifest_version\": 2,\n  \"name\": \"Taprac\",\n  \"version\": \"1.0.0\",\n  \"description\": \"Auto-fill job applications using your Taprac (Bubble) profile.\",\n  \"icons\": {\n    \"16\": \"icons/icon16.png\",\n    \"48\": \"icons/icon48.png\",\n    \"128\": \"icons/icon128.png\"\n  },\n  \"permissions\": [\n    \"storage\",\n    \"activeTab\",\n    \"https://kimmiysaa.bubbleapps.io/*\",\n    \"<all_urls>\"\n  ],\n  \"background\": {\n    \"scripts\": [\"background.js\"]\n  },\n  \"content_scripts\": [\n    {\n      \"matches\": [\"<all_urls>\"],\n      \"js\": [\n        \"browser-polyfill.js\",\n        \"config.js\",\n        \"content.js\",\n        \"job-scraper.js\",\n        \"form-filler.js\"\n      ],\n      \"run_at\": \"document_idle\"\n    }\n  ],\n  \"web_accessible_resources\": [\n    \"sidebar.html\",\n    \"sidebar.css\",\n    \"login-popup.html\",\n    \"login-popup.css\",\n    \"icons/*\"\n  ]\n}\n